---
import '../styles/site.css';
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Gallery | Cornwall Pet Spa</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="preload" href="/P3611/fonts/nunito-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/P3611/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin />
  </head>
  <body class="bg-brand-bg">

    <!-- Preview banner -->
    <div class="bg-brand-accent text-white py-2 px-4 text-center text-sm">
      <div class="max-w-4xl mx-auto flex items-center justify-center gap-3 flex-wrap">
        <span>Preview for <strong>Cornwall Pet Spa</strong> by <strong>Biscuit Web</strong></span>
        <a href="https://biscuitweb.co.uk/activate?id=P3611&name=Cornwall%20Pet%20Spa" class="inline-flex items-center px-4 py-1 bg-white text-brand-accent font-bold text-xs rounded-full hover:opacity-80 transition-opacity shrink-0">
          Like it? Just &pound;20/month
        </a>
      </div>
    </div>

    <!-- Nav -->
    <header class="bg-white border-b border-border sticky top-0 z-40">
      <div class="mx-auto max-w-7xl px-6 py-4 flex items-center justify-between">
        <a href="/P3611" class="font-display font-extrabold text-xl text-ink">🐾 Cornwall Pet Spa</a>
        <button class="md:hidden p-2 text-ink-soft" onclick="document.getElementById('mobile-nav-P3611').classList.toggle('hidden')" aria-label="Menu">
          <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
        </button>
        <nav class="hidden md:flex items-center gap-8">
          <a href="/P3611" class="text-sm text-ink-soft hover:text-brand-accent font-semibold transition-colors">Home</a>
          <a href="/P3611/services" class="text-sm text-ink-soft hover:text-brand-accent font-semibold transition-colors">Services</a>
          <a href="/P3611/gallery" class="text-sm text-brand-accent font-semibold transition-colors">Gallery</a>
          <a href="/P3611/contact" class="text-sm text-ink-soft hover:text-brand-accent font-semibold transition-colors">Contact</a>
          <a href="/P3611/contact" class="inline-flex items-center px-5 py-2 bg-brand-accent text-white font-display font-bold text-sm rounded hover:opacity-90 transition-opacity">Get in touch</a>
        </nav>
      </div>
      <nav id="mobile-nav-P3611" class="hidden md:hidden px-6 pb-4 space-y-3">
        <a href="/P3611" class="text-ink-soft block text-sm font-semibold hover:text-brand-accent">Home</a>
        <a href="/P3611/services" class="text-ink-soft block text-sm font-semibold hover:text-brand-accent">Services</a>
        <a href="/P3611/gallery" class="text-ink-soft block text-sm font-semibold hover:text-brand-accent">Gallery</a>
        <a href="/P3611/contact" class="text-ink-soft block text-sm font-semibold hover:text-brand-accent">Contact</a>
        <a href="/P3611/contact" class="block px-5 py-2.5 bg-brand-accent text-white font-display font-bold text-sm rounded text-center hover:opacity-90 transition-opacity">Get in touch</a>
      </nav>
    </header>


    <section class="relative py-20 sm:py-28 overflow-hidden">
      <img src="/P3611/images/472556232-1698316604079932-2995260217847-3.jpg" alt="" class="absolute inset-0 w-full h-full object-cover z-[1]" loading="lazy" />
      <div class="absolute inset-0 z-[2] bg-black/60"></div>
      <div class="relative z-[3] mx-auto max-w-4xl px-6">
        <h1 class="font-display font-extrabold text-4xl sm:text-5xl text-white">Gallery</h1>
        <p class="mt-4 text-white/70 text-lg">Cornwall Pet Spa in action.</p>
      </div>
    </section>

    <section class="bg-cream-dark py-20">
      <div class="mx-auto max-w-7xl px-6">
        <h2 class="font-display font-extrabold text-3xl text-ink mb-10 text-center">Gallery</h2>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
          
          <div class="rounded-xl overflow-hidden bg-cream-dark aspect-square">
            <img src="/P3611/images/482004678-1550915655861220-7013499775523-3.jpg" alt="" class="w-full h-full object-cover object-center hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="rounded-xl overflow-hidden bg-cream-dark aspect-square">
            <img src="/P3611/images/472556232-1698316604079932-2995260217847-3.jpg" alt="" class="w-full h-full object-cover object-center hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="rounded-xl overflow-hidden bg-cream-dark aspect-square">
            <img src="/P3611/images/472378043-1698297934081799-3047511035472-3.jpg" alt="" class="w-full h-full object-cover object-center hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="rounded-xl overflow-hidden bg-cream-dark aspect-square">
            <img src="/P3611/images/472690215-1698297717415154-1135992444644-3.jpg" alt="" class="w-full h-full object-cover object-center hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="rounded-xl overflow-hidden bg-cream-dark aspect-square">
            <img src="/P3611/images/472608788-1698316864079906-3427687733094-3.jpg" alt="" class="w-full h-full object-cover object-center hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="rounded-xl overflow-hidden bg-cream-dark aspect-square">
            <img src="/P3611/images/301723381-931562384463220-28422648867401-4.jpg" alt="" class="w-full h-full object-cover object-center hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="rounded-xl overflow-hidden bg-cream-dark aspect-square">
            <img src="/P3611/images/472512481-1697598334151759-3532700829505-2.jpg" alt="" class="w-full h-full object-cover object-center hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
        </div>
      </div>
    </section>


    <footer class="bg-cream-dark border-t border-border py-12">
      <div class="mx-auto max-w-7xl px-6">
        <div class="flex flex-col md:flex-row justify-between gap-8">
          <div>
            <p class="font-display font-extrabold text-lg text-ink">Cornwall Pet Spa</p>
            <p class="mt-2 text-ink-soft text-sm">Mount Hawke  Truro TR4 8DU</p>
            <p class="mt-2"><a href="tel:07976754934" class="text-brand-accent hover:underline text-sm">07976 754934</a></p>
            
          </div>
          
          <nav class="flex flex-wrap gap-6">
            <a href="/P3611" class="text-ink-soft hover:text-brand-accent text-sm transition-colors">Home</a>
            <a href="/P3611/services" class="text-ink-soft hover:text-brand-accent text-sm transition-colors">Services</a>
            <a href="/P3611/gallery" class="text-ink-soft hover:text-brand-accent text-sm transition-colors">Gallery</a>
            <a href="/P3611/contact" class="text-ink-soft hover:text-brand-accent text-sm transition-colors">Contact</a>
          </nav>
        </div>
        <div class="mt-8 pt-6 border-t border-border">
          <p class="text-ink-whisper text-xs">&copy; 2026 Cornwall Pet Spa. All rights reserved.</p>
        </div>
      </div>
    </footer>

  </body>
</html>
